# ═══════════════════════════════════════════════════════════════════════════════
# AI Incident Root Cause Analyzer — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Required: Groq API key for LLaMA 3.3 70B inference (https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Optional: OpenAI API key as fallback model (https://platform.openai.com)
OPENAI_API_KEY=sk-your_openai_api_key_here

# ── Vector Database (RAG) ────────────────────────────────────────────────────
# Optional: Pinecone for semantic search over historical incidents
PINECONE_API_KEY=pcsk_your_pinecone_api_key_here
PINECONE_ENV=us-east-1

# ── Security ─────────────────────────────────────────────────────────────────
# Required: Secret key for signing JWT authentication tokens
# Generate one with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_secure_random_string
